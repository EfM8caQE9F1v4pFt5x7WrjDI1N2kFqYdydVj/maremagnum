# ── Maremagnum · credenziali Cloudflare ──────────────────────────────
# QUESTO FILE NON VA MAI COMMITTATO (è in .gitignore).
#
# Il token si crea da: dash.cloudflare.com → My Profile → API Tokens →
# "Create Token". Permessi consigliati per il Maremagnum (deploy con
# wrangler di Workers + Durable Objects, KV, R2, D1, Queues, Workers AI):
#   Account · Workers Scripts        · Edit
#   Account · Workers KV Storage     · Edit
#   Account · Workers R2 Storage     · Edit
#   Account · D1                     · Edit
#   Account · Queues                 · Edit
#   Account · Workers AI             · Edit
#
# L'Account ID è nella colonna destra della dashboard (Workers & Pages).

# Variabili standard lette da wrangler:
CLOUDFLARE_API_TOKEN=xxxx_esempio_non_valido
CLOUDFLARE_ACCOUNT_ID=xxxx_esempio_non_valido

# Facoltative, per quando salperà l'Atlante:
# MAREMAGNUM_CF_ZONE_ID=
# MAREMAGNUM_ATLANTE_URL=

# ── Segreti a RUNTIME del Worker (non credenziali di deploy) ──────────
# NON si mettono qui a mani nude: sono segreti del Worker, si caricano con
#   npx wrangler secret put <NOME>
# (in produzione), oppure in cf/.dev.vars per `wrangler dev` in locale.
#
#   SESSION_SECRET   firma i token di sessione dell'Ancoraggio (TOTP).
#   ADMIN_SECRET     lasciapassare dell'Ammiragliato per le rotte protette,
#                    incluso l'innesco manuale del Mastro di Rotte:
#                      curl -X POST https://<host>/ammiragliato/mastro \
#                           -H "X-Ammiragliato: $ADMIN_SECRET"
#                    (batte il cron del lunedì: prime uscite e collaudi).
# ADMIN_SECRET=xxxx_esempio_non_valido
# SESSION_SECRET=xxxx_esempio_non_valido
